@page "/setup"
@inject GitHubStorageService GitHub
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="card">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="bi bi-key-fill text-primary" style="font-size: 2.5rem;"></i>
                    <h3 class="mt-2">FluxDeploy License Manager</h3>
                    <p class="text-body-secondary">
                        Enter your GitHub Personal Access Token to connect.
                    </p>
                </div>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger">@_error</div>
                }
                @if (!string.IsNullOrEmpty(_warning))
                {
                    <div class="alert alert-warning">@_warning</div>
                }
                @if (!string.IsNullOrEmpty(_success))
                {
                    <div class="alert alert-success">@_success</div>
                }

                <div class="mb-3">
                    <label class="form-label">Personal Access Token</label>
                    <input type="password" class="form-control" @bind="_token" @bind:event="oninput"
                           @onkeydown="OnKeyDown" placeholder="github_pat_xxxxxxxxxxxx" />
                    <div class="form-text">
                        Use a <strong>fine-grained</strong> token (starts with <code>github_pat_</code>) scoped to the data repository only.
                    </div>
                </div>

                <button class="btn btn-primary w-100" @onclick="ValidateAndSave" disabled="@_validating">
                    @if (_validating)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Connect
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private string _token = "";
    private string? _error;
    private string? _warning;
    private string? _success;
    private bool _validating;

    protected override async Task OnInitializedAsync()
    {
        await GitHub.LoadConfigAsync();
        if (GitHub.Config != null)
            _token = GitHub.Config.Token;
    }

    private async Task OnKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ValidateAndSave();
    }

    private async Task ValidateAndSave()
    {
        _error = null;
        _warning = null;
        _success = null;

        if (string.IsNullOrWhiteSpace(_token))
        {
            _error = "Token is required.";
            return;
        }

        _validating = true;
        try
        {
            await GitHub.SaveConfigAsync(new GitHubConfig { Token = _token.Trim() });

            // WEB-002: Validation now returns a warning for classic PATs
            var (ok, error, warning) = await GitHub.ValidateAccessAsync();
            if (!ok)
            {
                _error = error;
                await GitHub.ClearConfigAsync();
                return;
            }

            _warning = warning;
            _success = "Connected.";

            // If there's a warning (classic PAT), let the user see it before navigating
            if (warning != null)
            {
                StateHasChanged();
                await Task.Delay(3000);
            }
            else
            {
                await Task.Delay(500);
            }

            await JS.InvokeVoidAsync("navigateToBase");
        }
        catch
        {
            // WEB-008: Generic error message
            _error = "Unable to connect. Check your token and try again.";
            await GitHub.ClearConfigAsync();
        }
        finally
        {
            _validating = false;
        }
    }
}
