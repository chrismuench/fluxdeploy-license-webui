@page "/setup"
@inject GitHubStorageService GitHub
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="bi bi-github text-primary" style="font-size: 2.5rem;"></i>
                    <h3 class="mt-2">Connect to GitHub</h3>
                    <p class="text-body-secondary">
                        License records are stored in a private GitHub repo named
                        <code>@GitHubConfig.RequiredRepo</code>. Create this repo under your account,
                        then generate a fine-grained PAT with <strong>Contents: Read and write</strong>
                        scoped to that repo.
                    </p>
                </div>

                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger">@_error</div>
                }
                @if (!string.IsNullOrEmpty(_success))
                {
                    <div class="alert alert-success">@_success</div>
                }

                <div class="mb-3">
                    <label class="form-label">GitHub Username</label>
                    <input type="text" class="form-control" @bind="_owner" @bind:event="oninput"
                           placeholder="your-username" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Personal Access Token</label>
                    <input type="password" class="form-control" @bind="_token" @bind:event="oninput"
                           placeholder="github_pat_xxxxxxxxxxxx" />
                    <div class="form-text">
                        Fine-grained token with <strong>Contents: Read and write</strong> on
                        <code>@GitHubConfig.RequiredRepo</code> only.
                    </div>
                </div>

                <div class="mb-3 p-3 rounded" style="background: var(--bs-tertiary-bg);">
                    <small class="text-body-secondary">
                        <strong>Repository:</strong> <code>@(_owner.Length > 0 ? _owner : "username")/@GitHubConfig.RequiredRepo</code><br />
                        <strong>File:</strong> <code>@GitHubConfig.FilePath</code>
                    </small>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-primary" @onclick="ValidateAndSave" disabled="@_validating">
                        @if (_validating)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Connect
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string _token = "";
    private string _owner = "";
    private string? _error;
    private string? _success;
    private bool _validating;

    protected override async Task OnInitializedAsync()
    {
        await GitHub.LoadConfigAsync();
        if (GitHub.Config != null)
        {
            _token = GitHub.Config.Token;
            _owner = GitHub.Config.Owner;
        }
    }

    private async Task ValidateAndSave()
    {
        _error = null;
        _success = null;

        if (string.IsNullOrWhiteSpace(_owner) || string.IsNullOrWhiteSpace(_token))
        {
            _error = "Username and token are required.";
            return;
        }

        _validating = true;
        try
        {
            // Save config first so ValidateAccessAsync can use it
            await GitHub.SaveConfigAsync(new GitHubConfig
            {
                Token = _token.Trim(),
                Owner = _owner.Trim()
            });

            var (ok, error) = await GitHub.ValidateAccessAsync();
            if (!ok)
            {
                _error = error;
                await GitHub.ClearConfigAsync();
                return;
            }

            _success = "Connected successfully.";
            await Task.Delay(500);
            await JS.InvokeVoidAsync("navigateToBase");
        }
        catch (Exception ex)
        {
            _error = $"Connection failed: {ex.Message}";
            await GitHub.ClearConfigAsync();
        }
        finally
        {
            _validating = false;
        }
    }
}
